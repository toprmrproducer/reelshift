---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonicalPath?: string;
}

const { title, description, canonicalPath = '/' } = Astro.props;
// normalize BASE_URL to always have a trailing slash so string concatenation
// (`${base}about`) never collides with the path segment (e.g. "/reelshiftabout")
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const joinedPath = base.slice(0, -1) + canonicalPath;
const canonical = new URL(joinedPath, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<!--
			Security hardening for a fully static, client-side tool.
			GitHub Pages cannot set HTTP response headers, so the equivalents are
			declared here. NOTE: we deliberately do NOT set Cross-Origin-Embedder-
			Policy: require-corp — the single-threaded @ffmpeg/core build does not
			need SharedArrayBuffer, and require-corp would block the cross-origin
			fetch of the wasm core from unpkg. CSP still locks the origin down.
		-->
		<meta
			http-equiv="Content-Security-Policy"
			content="default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' https://unpkg.com blob: data:; worker-src 'self' blob:; base-uri 'self'; form-action 'self'; object-src 'none'"
		/>
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen bg-white font-sans text-[#4A4234] antialiased">
		<header class="border-b border-[#EAE4D6] bg-white">
			<!--
				The content column is hard-capped at 820px and centered. The empty
				left/right gutters at desktop widths (~310px each at 1440px) are
				reserved for AdSense skyscraper units. Do not widen the column.
			-->
			<nav class="mx-auto flex min-h-[64px] max-w-[820px] items-center justify-between px-6 py-4">
				<a
					href={base}
					class="font-display text-xl font-bold tracking-tight text-[#221B10]"
				>
					Reel<span class="text-[#C9982E]">Shift</span>
				</a>
				<div class="hidden items-center gap-7 text-sm font-semibold text-[#4A4234] sm:flex">
					<a href={`${base}faq`} class="py-2.5 transition hover:text-[#B8860B]">FAQ</a>
					<a href={`${base}about`} class="py-2.5 transition hover:text-[#B8860B]">About</a>
				</div>
			</nav>
		</header>

		<!--
			Top leaderboard ad slot. Reserved + invisible until a real unit is
			dropped in. Sits directly below the header, above the main content.
		-->
		<div class="ad-slot ad-leaderboard mx-auto px-6" data-ad-slot="leaderboard" style="max-width:970px;min-height:0">
			<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
		</div>

		<!--
			Content row: [left skyscraper][820px main][right skyscraper].
			Skyscrapers only render at >=1280px (xl) and sit in the empty gutter
			beside the capped 820px column. They are sticky so they track scroll.
		-->
		<div class="mx-auto flex w-full max-w-[1180px] items-start justify-center gap-6 px-0 xl:max-w-[1240px]">
			<aside
				class="ad-skyscraper-wrap hidden shrink-0 xl:block"
				aria-hidden="true"
			>
				<div
					class="ad-slot sticky w-[160px]"
					data-ad-slot="skyscraper-left"
					style="top:120px;min-height:0"
				>
					<!-- AdSense: paste vertical <ins class="adsbygoogle"> here -->
				</div>
			</aside>

			<!-- pt/pb ≈ 96-112px: vertical breathing room reserved for future ad units -->
			<main class="mx-auto w-full max-w-[820px] px-6 pt-24 pb-28">
				<slot />

				<!--
					Bottom in-article ad slot. Reserved + invisible, just above the
					footer, centered, capped at 728px.
				-->
				<div class="ad-slot ad-in-article mx-auto mt-16" data-ad-slot="in-article" style="max-width:728px;min-height:0">
					<!-- AdSense: paste in-article <ins class="adsbygoogle"> here -->
				</div>
			</main>

			<aside
				class="ad-skyscraper-wrap hidden shrink-0 xl:block"
				aria-hidden="true"
			>
				<div
					class="ad-slot sticky w-[160px]"
					data-ad-slot="skyscraper-right"
					style="top:120px;min-height:0"
				>
					<!-- AdSense: paste vertical <ins class="adsbygoogle"> here -->
				</div>
			</aside>
		</div>

		<footer class="border-t border-[#EAE4D6] bg-[#FAF8F3]">
			<div class="mx-auto max-w-[820px] px-6 py-12 text-sm text-[#4A4234]">
				<p>
					All conversions run locally in your browser. Nothing you upload is
					ever sent to a server.
				</p>
				<div class="mt-5 flex flex-wrap gap-x-7 gap-y-3 font-medium">
					<a href={`${base}about`} class="py-1 transition hover:text-[#B8860B]">About</a>
					<a href={`${base}privacy`} class="py-1 transition hover:text-[#B8860B]">Privacy Policy</a>
					<a href={`${base}faq`} class="py-1 transition hover:text-[#B8860B]">FAQ</a>
				</div>
				<p class="mt-5 text-[#857A67]">&copy; {new Date().getFullYear()} ReelShift</p>
			</div>
		</footer>
	</body>
</html>
