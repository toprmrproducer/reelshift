---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Privacy Policy — ReelShift"
	description="ReelShift privacy policy: all video conversion happens locally in your browser, no files are uploaded or stored."
	canonicalPath="/privacy"
>
	<div class="mx-auto max-w-2xl">
		<h1 class="font-display text-3xl font-semibold tracking-tight text-[#2B2013]">
			Privacy Policy
		</h1>
		<div class="mt-6 space-y-4 text-[#5C4F3D]">
			<p>
				Files you select in ReelShift are processed entirely on your own
				device, inside your browser. They are never uploaded to, or stored
				on, any server operated by ReelShift.
			</p>
			<p>
				ReelShift uses standard web analytics to understand aggregate traffic
				(page views, referrers) and may display advertising through Google
				AdSense, which can set its own cookies subject to Google's own
				privacy policy.
			</p>
			<p>
				If you have questions about this policy, contact us via the details
				on the About page.
			</p>
		</div>
	</div>
</Layout>
