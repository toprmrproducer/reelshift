---
import Layout from '../layouts/Layout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<Layout
	title="ReelShift — Convert Video Files, Privately, In Your Browser"
	description="Convert video between MP4, WebM, GIF, and MP3 entirely on your device. No uploads, no accounts, nothing ever leaves your computer."
	canonicalPath="/"
>
	<section class="text-center">
		<p class="text-sm font-bold uppercase tracking-[0.2em] text-[#C9982E]">
			Private video conversion
		</p>
		<h1 class="mt-4 font-display text-4xl font-extrabold tracking-tight text-[#221B10] sm:text-5xl">
			Convert video files, without uploading anything.
		</h1>
		<p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-[#4A4234]">
			ReelShift converts between <strong class="text-[#221B10]">MP4</strong>, <strong class="text-[#221B10]">WebM</strong>, <strong class="text-[#221B10]">GIF</strong>, and extracts <strong class="text-[#221B10]">MP3</strong> audio — entirely inside your
			browser. A real build of FFmpeg runs on WebAssembly, right on your
			device. Nothing you select is ever sent anywhere.
		</p>
	</section>

	<section class="mt-14">
		<div class="rounded-2xl border border-[#EAE4D6] bg-[#FAF8F3] p-6 shadow-[0_1px_2px_rgba(34,27,16,0.04),0_10px_28px_rgba(34,27,16,0.06)] sm:p-8">
			<div class="grid gap-6 sm:grid-cols-2">
				<div>
					<label
						for="file-input"
						class="mb-2 block text-sm font-semibold text-[#221B10]"
					>
						Choose video files
					</label>
					<input
						id="file-input"
						type="file"
						accept="video/*"
						multiple
						class="block min-h-[48px] w-full cursor-pointer rounded-xl border border-[#EAE4D6] bg-white text-sm text-[#4A4234] file:mr-4 file:h-[46px] file:cursor-pointer file:rounded-l-xl file:border-0 file:bg-[#C9982E] file:px-5 file:text-sm file:font-semibold file:text-white hover:file:bg-[#B8860B]"
					/>
					<p class="mt-2 text-xs text-[#857A67]">
						You can select more than one file — they'll be converted one
						after another.
					</p>
				</div>

				<div>
					<label
						for="format-select"
						class="mb-2 block text-sm font-semibold text-[#221B10]"
					>
						Convert to
					</label>
					<select
						id="format-select"
						class="block min-h-[48px] w-full rounded-xl border border-[#EAE4D6] bg-white px-4 py-2.5 text-sm text-[#221B10] focus:border-[#C9982E] focus:outline-none"
					>
						<option value="mp4">MP4 (H.264)</option>
						<option value="webm">WebM</option>
						<option value="gif">GIF (animated)</option>
						<option value="mp3">MP3 (audio only)</option>
					</select>
					<p id="format-note" class="mt-2 text-xs text-[#857A67]">
						The whole batch converts to this one format.
					</p>
				</div>
			</div>

			<!-- ===== Trim + resolution controls ===== -->
			<div class="mt-6 rounded-xl border border-[#EAE4D6] bg-white p-4 sm:p-5">
				<div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
					<span class="text-sm font-semibold text-[#221B10]">Trim &amp; resize</span>
					<span class="text-xs text-[#857A67]">optional — clip a segment and pick an output size</span>
				</div>

				<!-- Dual range sliders. Enabled once the first video's duration is
				     known; before that (or for audio with no video track) the
				     numeric inputs below still accept typed times. -->
				<div id="trim-slider-wrap" class="mt-4">
					<div class="mb-2 flex items-center justify-between text-xs font-semibold text-[#4A4234]">
						<span>Start: <span id="trim-start-label" class="text-[#B8860B]">0:00</span></span>
						<span>End: <span id="trim-end-label" class="text-[#B8860B]">end</span></span>
					</div>
					<div class="relative py-2">
						<input
							id="trim-start-range"
							type="range"
							min="0"
							max="100"
							step="0.1"
							value="0"
							aria-label="Trim start time"
							class="trim-range block w-full accent-[#C9982E]"
						/>
						<input
							id="trim-end-range"
							type="range"
							min="0"
							max="100"
							step="0.1"
							value="100"
							aria-label="Trim end time"
							class="trim-range mt-3 block w-full accent-[#C9982E]"
						/>
					</div>
					<p id="trim-duration-note" class="mt-1 text-xs text-[#857A67]">
						Select one or more videos and the sliders snap to the first video's length.
					</p>
				</div>

				<!-- Numeric fallback / precise entry. Kept in sync with the sliders. -->
				<div class="mt-4 grid gap-4 sm:grid-cols-2">
					<div>
						<label for="trim-start" class="mb-1.5 block text-xs font-semibold text-[#4A4234]">
							Start time
						</label>
						<input
							id="trim-start"
							type="text"
							inputmode="numeric"
							placeholder="e.g. 0:05 or 5"
							autocomplete="off"
							class="block min-h-[44px] w-full rounded-xl border border-[#EAE4D6] bg-white px-4 text-sm text-[#221B10] placeholder-[#B7AD9B] focus:border-[#C9982E] focus:outline-none"
						/>
					</div>
					<div>
						<label for="trim-end" class="mb-1.5 block text-xs font-semibold text-[#4A4234]">
							End time
						</label>
						<input
							id="trim-end"
							type="text"
							inputmode="numeric"
							placeholder="e.g. 1:30 or 90"
							autocomplete="off"
							class="block min-h-[44px] w-full rounded-xl border border-[#EAE4D6] bg-white px-4 text-sm text-[#221B10] placeholder-[#B7AD9B] focus:border-[#C9982E] focus:outline-none"
						/>
					</div>
				</div>
				<p class="mt-2 text-xs text-[#857A67]">
					Accepts seconds (<code>90</code>), <code>m:ss</code> (<code>1:30</code>), or <code>h:mm:ss</code>. Leave blank to convert the whole video.
				</p>

				<!-- Output resolution -->
				<div class="mt-5 border-t border-[#EAE4D6] pt-4">
					<label for="res-select" class="mb-1.5 block text-xs font-semibold text-[#4A4234]">
						Output resolution
					</label>
					<select
						id="res-select"
						class="block min-h-[44px] w-full max-w-xs rounded-xl border border-[#EAE4D6] bg-white px-4 text-sm text-[#221B10] focus:border-[#C9982E] focus:outline-none"
					>
						<option value="keep">Keep original size</option>
						<option value="720">Scale down to 720p</option>
						<option value="480">Scale down to 480p</option>
					</select>
					<p id="res-note" class="mt-1.5 text-xs text-[#857A67]">
						Scaling only ever shrinks a video — larger sources are downscaled, smaller ones are left untouched. Ignored for MP3.
					</p>
				</div>
			</div>

			<button
				id="convert-btn"
				type="button"
				disabled
				class="mt-6 w-full min-h-[48px] rounded-xl bg-[#C9982E] px-7 py-3 text-sm font-bold text-white transition hover:bg-[#B8860B] disabled:cursor-not-allowed disabled:opacity-40 sm:w-auto"
			>
				Convert
			</button>

			<div id="engine-status-wrap" class="mt-6 hidden">
				<div class="flex items-center justify-between text-sm">
					<span id="engine-status-text" aria-live="polite" class="text-[#4A4234]">Idle</span>
					<span id="engine-status-percent" class="text-[#857A67]">0%</span>
				</div>
				<div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-[#EFEAE0]">
					<div
						id="engine-progress-bar"
						class="h-full w-0 rounded-full bg-[#C9982E] transition-all duration-150"
					>
					</div>
				</div>
			</div>

			<div
				id="error-box"
				role="alert"
				class="mt-6 hidden rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700"
			>
			</div>

			<!-- Per-file queue cards -->
			<div id="queue-list" class="mt-6 flex flex-col gap-3"></div>
		</div>

		<!-- ===== Snake boredom-filler (slow-tool surfacing) ===== -->
		<section class="mx-auto mt-14 max-w-[820px]">
			<details id="snake-details" class="rounded-2xl border border-[#EAE4D6] bg-[#FAF8F3] p-5">
				<summary class="cursor-pointer select-none font-display text-lg font-bold text-[#221B10]">
					<span id="snake-summary-text">Bored? Play a quick game of Snake</span>
				</summary>
				<div class="mt-4 flex flex-col items-center gap-3">
					<canvas
						id="snake-canvas"
						width="320"
						height="320"
						class="rounded-lg border border-[#EAE4D6] bg-white"
						style="touch-action:none"
					></canvas>
					<div class="flex items-center gap-4 text-sm text-[#4A4234]">
						<span>Score: <b id="snake-score">0</b></span>
						<button
							id="snake-restart"
							type="button"
							class="rounded-lg bg-[#C9982E] px-4 py-2 font-semibold text-white transition hover:bg-[#B8860B]"
						>
							Restart
						</button>
					</div>
					<p class="text-xs text-[#857A67]">Arrow keys / WASD, or swipe on mobile.</p>
				</div>
			</details>
		</section>

		<div class="mt-8 rounded-2xl border border-[#EAE4D6] bg-[#FAF8F3] p-6 text-sm text-[#4A4234]">
			<p>
				<strong class="text-[#221B10]">Supported conversions:</strong>
				any browser-playable video source can be converted to MP4 (H.264 video,
				AAC-compatible container), WebM, an animated GIF (downscaled to 480px
				wide at 10fps for a reasonable file size), or MP3 audio extracted from
				the video's soundtrack. The first time you convert something, your
				browser downloads a small (~30MB) conversion engine and caches it —
				every conversion after that starts instantly. Very large files or
				exotic codecs may take longer or fail depending on your device's
				memory. Files in a batch are converted one at a time, in order, so
				memory use stays bounded regardless of queue size.
			</p>
		</div>

		<div class="mt-8 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm font-medium text-[#4A4234]">
			<a href={`${base}about`} class="py-1 underline decoration-[#EAE4D6] underline-offset-4 transition hover:text-[#B8860B]">
				About ReelShift
			</a>
			<a href={`${base}faq`} class="py-1 underline decoration-[#EAE4D6] underline-offset-4 transition hover:text-[#B8860B]">
				Frequently Asked Questions
			</a>
			<a href={`${base}privacy`} class="py-1 underline decoration-[#EAE4D6] underline-offset-4 transition hover:text-[#B8860B]">
				Privacy Policy
			</a>
		</div>
	</section>

	<script>
		type QueueItem = {
			id: string;
			file: File;
		};

		const fileInput = document.getElementById(
			'file-input',
		) as HTMLInputElement;
		const formatSelect = document.getElementById(
			'format-select',
		) as HTMLSelectElement;
		const formatNote = document.getElementById(
			'format-note',
		) as HTMLParagraphElement;
		const convertBtn = document.getElementById(
			'convert-btn',
		) as HTMLButtonElement;
		const trimStartInput = document.getElementById(
			'trim-start',
		) as HTMLInputElement;
		const trimEndInput = document.getElementById(
			'trim-end',
		) as HTMLInputElement;
		const trimStartRange = document.getElementById(
			'trim-start-range',
		) as HTMLInputElement;
		const trimEndRange = document.getElementById(
			'trim-end-range',
		) as HTMLInputElement;
		const trimStartLabel = document.getElementById(
			'trim-start-label',
		) as HTMLSpanElement;
		const trimEndLabel = document.getElementById(
			'trim-end-label',
		) as HTMLSpanElement;
		const trimDurationNote = document.getElementById(
			'trim-duration-note',
		) as HTMLParagraphElement;
		const resSelect = document.getElementById(
			'res-select',
		) as HTMLSelectElement;
		const engineStatusWrap = document.getElementById(
			'engine-status-wrap',
		) as HTMLDivElement;
		const engineStatusText = document.getElementById(
			'engine-status-text',
		) as HTMLSpanElement;
		const engineStatusPercent = document.getElementById(
			'engine-status-percent',
		) as HTMLSpanElement;
		const engineProgressBar = document.getElementById(
			'engine-progress-bar',
		) as HTMLDivElement;
		const errorBox = document.getElementById('error-box') as HTMLDivElement;
		const queueList = document.getElementById('queue-list') as HTMLDivElement;

		let ffmpeg: any = null;
		let ffmpegLoaded = false;
		let queue: QueueItem[] = [];
		let currentCard: HTMLDivElement | null = null;
		let isProcessing = false;
		// Ring buffer of recent ffmpeg log lines, used to turn opaque failures
		// into honest, specific error messages.
		let recentLogs: string[] = [];

		const DEFAULT_FORMAT_NOTE = 'The whole batch converts to this one format.';
		const WEBM_NOTE =
			'Heads up: WebM encoding is much slower than MP4 in the browser — a large file can take several minutes. As long as the progress bar is moving, it’s working.';

		function showEngineStatus(text: string, percent?: number) {
			engineStatusWrap.classList.remove('hidden');
			engineStatusText.textContent = text;
			if (typeof percent === 'number') {
				const clamped = Math.max(0, Math.min(100, Math.round(percent)));
				engineStatusPercent.textContent = `${clamped}%`;
				engineProgressBar.style.width = `${clamped}%`;
			}
		}

		function hideEngineStatus() {
			engineStatusWrap.classList.add('hidden');
			engineProgressBar.style.width = '0%';
			engineStatusPercent.textContent = '0%';
		}

		function showError(message: string) {
			errorBox.classList.remove('hidden');
			errorBox.textContent = message;
		}

		function clearError() {
			errorBox.classList.add('hidden');
			errorBox.textContent = '';
		}

		// Any user-controlled text (filenames, etc.) rendered via innerHTML MUST
		// go through this helper first.
		const escapeHtml = (str: string): string =>
			str
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')
				.replace(/'/g, '&#39;');

		function renderQueueButtonState() {
			convertBtn.disabled = isProcessing || queue.length === 0;
		}

		// ---------- Trim parsing ----------

		// "90" | "90.5" | "1:30" | "01:02:03" -> seconds, or null for blank.
		// Throws with a friendly message for anything unparseable.
		function parseTimestamp(raw: string, label: string): number | null {
			const value = raw.trim();
			if (value === '') return null;
			if (!/^\d+(\.\d+)?(:\d{1,2}(\.\d+)?){0,2}$/.test(value)) {
				throw new Error(
					`"${value}" isn't a valid ${label}. Use seconds (90), m:ss (1:30), or h:mm:ss.`,
				);
			}
			const parts = value.split(':').map(Number);
			if (parts.some((n) => Number.isNaN(n))) {
				throw new Error(`"${value}" isn't a valid ${label}.`);
			}
			let seconds = 0;
			for (const part of parts) seconds = seconds * 60 + part;
			return seconds;
		}

		// Returns {start, end} in seconds (either may be null), or throws.
		function readTrimRange(): { start: number | null; end: number | null } {
			const start = parseTimestamp(trimStartInput.value, 'start time');
			const end = parseTimestamp(trimEndInput.value, 'end time');
			if (start !== null && end !== null && end <= start) {
				throw new Error(
					'Trim end time must be after the start time.',
				);
			}
			return { start, end };
		}

		// Resolution choice: 'keep' | 720 | 480. Null means keep original.
		function readResolution(): number | null {
			const v = resSelect.value;
			return v === '720' ? 720 : v === '480' ? 480 : null;
		}

		function round1(n: number): number {
			return Math.round(n * 10) / 10;
		}

		// A short m:ss label for the slider read-outs.
		function shortLabel(total: number): string {
			const m = Math.floor(total / 60);
			const s = Math.round(total % 60);
			return `${m}:${String(s).padStart(2, '0')}`;
		}

		function formatSeconds(total: number): string {
			const h = Math.floor(total / 3600);
			const m = Math.floor((total % 3600) / 60);
			const s = total % 60;
			const sStr = Number.isInteger(s) ? String(s).padStart(2, '0') : s.toFixed(2).padStart(5, '0');
			return h > 0
				? `${h}:${String(m).padStart(2, '0')}:${sStr}`
				: `${m}:${sStr}`;
		}

		// ---------- Trim range sliders + duration probe ----------
		// The first selected video's duration drives the slider scale. Sliders and
		// the numeric inputs are two-way bound; the numeric inputs stay the single
		// source of truth read at convert time (readTrimRange).

		let videoDuration: number | null = null; // seconds, or null if unknown

		function enableSliders(duration: number) {
			videoDuration = duration;
			trimStartRange.min = '0';
			trimEndRange.min = '0';
			trimStartRange.max = String(duration);
			trimEndRange.max = String(duration);
			const step = duration > 60 ? '1' : '0.1';
			trimStartRange.step = step;
			trimEndRange.step = step;
			trimStartRange.value = '0';
			trimEndRange.value = String(duration);
			trimStartRange.disabled = false;
			trimEndRange.disabled = false;
			trimDurationNote.textContent = `First video is ${shortLabel(duration)} long. Drag the handles to clip, or type exact times below.`;
			syncLabelsFromRanges();
		}

		function disableSliders(message: string) {
			videoDuration = null;
			trimStartRange.disabled = true;
			trimEndRange.disabled = true;
			trimStartRange.value = '0';
			trimEndRange.value = String(trimEndRange.max || '100');
			trimStartLabel.textContent = '0:00';
			trimEndLabel.textContent = 'end';
			trimDurationNote.textContent = message;
		}

		function syncLabelsFromRanges() {
			const s = parseFloat(trimStartRange.value);
			const e = parseFloat(trimEndRange.value);
			trimStartLabel.textContent = shortLabel(s);
			trimEndLabel.textContent =
				videoDuration !== null && e >= videoDuration ? 'end' : shortLabel(e);
		}

		// Slider drag -> update the paired numeric input. An untouched slider (start
		// at 0, end at full length) leaves the input blank so it still means
		// "convert the whole thing".
		function onRangeInput(which: 'start' | 'end') {
			if (videoDuration === null) return;
			let s = parseFloat(trimStartRange.value);
			let e = parseFloat(trimEndRange.value);
			// keep at least a 0.5s window and prevent crossover
			if (which === 'start' && s > e - 0.5) {
				s = Math.max(0, e - 0.5);
				trimStartRange.value = String(s);
			}
			if (which === 'end' && e < s + 0.5) {
				e = Math.min(videoDuration, s + 0.5);
				trimEndRange.value = String(e);
			}
			syncLabelsFromRanges();
			trimStartInput.value = s <= 0 ? '' : formatSeconds(round1(s));
			trimEndInput.value = e >= videoDuration ? '' : formatSeconds(round1(e));
		}

		// Numeric edit -> move the matching slider handle (best-effort; invalid text
		// is left for readTrimRange to report at convert time).
		function onTextInput() {
			if (videoDuration === null) return;
			try {
				const start = parseTimestamp(trimStartInput.value, 'start time');
				const end = parseTimestamp(trimEndInput.value, 'end time');
				if (start !== null && start >= 0 && start <= videoDuration) {
					trimStartRange.value = String(start);
				} else if (trimStartInput.value.trim() === '') {
					trimStartRange.value = '0';
				}
				if (end !== null && end >= 0 && end <= videoDuration) {
					trimEndRange.value = String(end);
				} else if (trimEndInput.value.trim() === '') {
					trimEndRange.value = String(videoDuration);
				}
				syncLabelsFromRanges();
			} catch {
				// ignore mid-typing invalid values
			}
		}

		trimStartRange.addEventListener('input', () => onRangeInput('start'));
		trimEndRange.addEventListener('input', () => onRangeInput('end'));
		trimStartInput.addEventListener('input', onTextInput);
		trimEndInput.addEventListener('input', onTextInput);
		disableSliders(
			'Select one or more videos and the sliders snap to the first video\u2019s length.',
		);

		// Probe the first video's duration via a throwaway <video> element. The
		// object URL is revoked after read so nothing lingers in memory.
		function probeDuration(file: File) {
			const url = URL.createObjectURL(file);
			const v = document.createElement('video');
			v.preload = 'metadata';
			v.muted = true;
			const cleanup = () => {
				URL.revokeObjectURL(url);
				v.removeAttribute('src');
				v.load();
			};
			const fail = () =>
				disableSliders(
					'Could not read this video\u2019s length automatically \u2014 type exact start/end times below instead.',
				);
			v.onloadedmetadata = () => {
				const d = v.duration;
				if (Number.isFinite(d) && d > 0) enableSliders(d);
				else fail();
				cleanup();
			};
			v.onerror = () => {
				fail();
				cleanup();
			};
			v.src = url;
		}

		// ---------- File intake ----------

		const VIDEO_EXTENSIONS = new Set([
			'mp4', 'm4v', 'mov', 'webm', 'mkv', 'avi', 'wmv', 'flv', 'mpg',
			'mpeg', 'ts', 'mts', 'm2ts', '3gp', 'ogv',
		]);

		function looksLikeVideo(file: File): boolean {
			if (file.type.startsWith('video/')) return true;
			// Some OS/browser combos hand over an empty MIME type — fall back to
			// the extension instead of silently dropping the file.
			if (file.type === '') {
				return VIDEO_EXTENSIONS.has(extensionOf(file.name));
			}
			return false;
		}

		function addFiles(files: FileList | File[]) {
			const all = Array.from(files);
			const incoming = all.filter(looksLikeVideo);
			const skipped = all.filter((f) => !looksLikeVideo(f));
			const wasEmpty = queue.length === 0;
			for (const file of incoming) {
				const item: QueueItem = {
					id: `${Date.now()}-${Math.random().toString(36).slice(2)}`,
					file,
				};
				queue.push(item);
				queueList.appendChild(createQueueCard(item));
			}
			// Probe the first video of a fresh batch so the trim sliders scale to
			// its real length.
			if (wasEmpty && incoming.length > 0) {
				trimDurationNote.textContent = 'Reading video length…';
				probeDuration(incoming[0]);
			}
			if (skipped.length > 0) {
				showError(
					`Skipped ${skipped.length} file${skipped.length > 1 ? 's' : ''} that ${skipped.length > 1 ? "aren't" : "isn't"} video: ${skipped
						.map((f) => f.name)
						.join(', ')}`,
				);
			}
			renderQueueButtonState();
		}

		fileInput.addEventListener('change', () => {
			clearError();
			if (fileInput.files && fileInput.files.length > 0) {
				addFiles(fileInput.files);
				// allow re-selecting the same file later
				fileInput.value = '';
			}
		});

		formatSelect.addEventListener('change', () => {
			formatNote.textContent =
				formatSelect.value === 'webm' ? WEBM_NOTE : DEFAULT_FORMAT_NOTE;
		});

		// ---------- Queue cards ----------

		function createQueueCard(item: QueueItem): HTMLDivElement {
			const card = document.createElement('div');
			card.className = 'rounded-xl border border-[#EAE4D6] bg-white p-4';
			card.id = `card-${item.id}`;
			card.innerHTML = `
				<div class="flex items-center justify-between gap-4">
					<p class="min-w-0 flex-1 truncate text-sm font-semibold text-[#221B10]">${escapeHtml(item.file.name)}</p>
					<span class="status-text shrink-0 text-xs text-[#857A67]">Ready</span>
					<button type="button" class="remove-btn shrink-0 rounded-lg px-2.5 py-1.5 text-xs font-semibold text-[#857A67] transition hover:bg-[#EFEAE0] hover:text-[#221B10]" aria-label="Remove ${escapeHtml(item.file.name)} from the queue">Remove</button>
				</div>
				<div class="mt-2 h-1.5 w-full overflow-hidden rounded-full bg-[#EFEAE0]">
					<div class="progress-bar h-full w-0 rounded-full bg-[#C9982E] transition-all duration-150"></div>
				</div>
				<div class="action-slot mt-3 hidden"></div>
			`;
			const removeBtn = card.querySelector('.remove-btn') as HTMLButtonElement;
			removeBtn.addEventListener('click', () => {
				if (isProcessing) return;
				queue = queue.filter((q) => q.id !== item.id);
				card.remove();
				renderQueueButtonState();
			});
			return card;
		}

		function hideRemoveButtons() {
			queueList
				.querySelectorAll('.remove-btn')
				.forEach((btn) => btn.classList.add('hidden'));
		}

		function setCardStatus(
			card: HTMLDivElement,
			text: string,
			isError = false,
		) {
			const statusEl = card.querySelector('.status-text');
			if (statusEl) {
				statusEl.textContent = text;
				statusEl.className = isError
					? 'status-text shrink-0 text-xs font-semibold text-red-600'
					: 'status-text shrink-0 text-xs text-[#857A67]';
			}
		}

		function setCardProgress(card: HTMLDivElement, percent: number) {
			const bar = card.querySelector('.progress-bar') as HTMLDivElement | null;
			if (bar) {
				const clamped = Math.max(0, Math.min(100, Math.round(percent)));
				bar.style.width = `${clamped}%`;
			}
		}

		function setCardAction(
			card: HTMLDivElement,
			url: string,
			filename: string,
		) {
			const slot = card.querySelector('.action-slot');
			if (slot) {
				slot.classList.remove('hidden');
				const link = document.createElement('a');
				link.href = url;
				link.download = filename;
				link.textContent = 'Download file';
				link.className =
					'inline-flex min-h-[40px] items-center gap-2 rounded-xl bg-[#C9982E] px-5 py-2 text-xs font-bold text-white transition hover:bg-[#B8860B]';
				slot.innerHTML = '';
				slot.appendChild(link);
			}
		}

		// ---------- Engine ----------

		async function getFfmpeg() {
			if (ffmpeg && ffmpegLoaded) return ffmpeg;

			const { FFmpeg } = await import('@ffmpeg/ffmpeg');
			const { toBlobURL } = await import('@ffmpeg/util');

			ffmpeg = new FFmpeg();

			ffmpeg.on('progress', ({ progress }: { progress: number }) => {
				if (typeof progress === 'number' && !Number.isNaN(progress)) {
					const percent = progress * 100;
					showEngineStatus('Converting…', percent);
					if (currentCard) {
						setCardProgress(currentCard, percent);
						setCardStatus(currentCard, `Converting… ${Math.round(Math.max(0, Math.min(100, percent)))}%`);
					}
				}
			});

			ffmpeg.on('log', ({ message }: { message: string }) => {
				// Kept for debugging AND for diagnosing failures honestly.
				recentLogs.push(message);
				if (recentLogs.length > 200) recentLogs.shift();
				console.debug('[ffmpeg]', message);
			});

			showEngineStatus('Loading converter engine…', 0);

			const coreVersion = '0.12.10';
			const baseURL = `https://unpkg.com/@ffmpeg/core@${coreVersion}/dist/esm`;

			const [coreURL, wasmURL] = await Promise.all([
				toBlobURL(`${baseURL}/ffmpeg-core.js`, 'text/javascript'),
				toBlobURL(`${baseURL}/ffmpeg-core.wasm`, 'application/wasm'),
			]);

			await ffmpeg.load({ coreURL, wasmURL });

			ffmpegLoaded = true;
			return ffmpeg;
		}

		// A wasm crash (e.g. "memory access out of bounds") leaves the engine
		// unusable — throw it away so the next file gets a fresh one.
		function resetEngine() {
			try {
				ffmpeg?.terminate();
			} catch {
				// already dead
			}
			ffmpeg = null;
			ffmpegLoaded = false;
		}

		function extensionOf(name: string): string {
			const parts = name.split('.');
			return parts.length > 1 ? (parts.pop() as string).toLowerCase() : '';
		}

		function buildCommand(
			inputName: string,
			outputName: string,
			format: string,
			trim: { start: number | null; end: number | null },
			resHeight: number | null,
		): string[] {
			// -ss/-to are placed BEFORE -i (input options): with re-encoding this
			// seeks fast and stays frame-accurate.
			const trimArgs: string[] = [];
			if (trim.start !== null) trimArgs.push('-ss', String(trim.start));
			if (trim.end !== null) trimArgs.push('-to', String(trim.end));

			// Downscale-only scale filter for mp4/webm. Using -2 for width keeps
			// the aspect ratio and forces an even dimension (required by yuv420p);
			// clamping the target height to the input height with min() means a
			// smaller source is never upscaled.
			const scaleFilter =
				resHeight !== null
					? `scale=-2:'min(ih,${resHeight})':flags=lanczos`
					: null;

			switch (format) {
				case 'mp4':
					return [
						...trimArgs,
						'-i',
						inputName,
						...(scaleFilter ? ['-vf', scaleFilter] : []),
						'-c:v',
						'libx264',
						'-preset',
						'ultrafast',
						'-pix_fmt',
						'yuv420p',
						outputName,
					];
				case 'webm':
					// Explicit VP8 realtime settings: the default libvpx path
					// ("good" deadline) crashes the single-threaded wasm build with
					// "memory access out of bounds" and would be minutes-slow even
					// when it survives.
					return [
						...trimArgs,
						'-i',
						inputName,
						...(scaleFilter ? ['-vf', scaleFilter] : []),
						'-c:v',
						'libvpx',
						'-deadline',
						'realtime',
						'-cpu-used',
						'5',
						'-b:v',
						'1M',
						'-c:a',
						'libvorbis',
						outputName,
					];
				case 'gif': {
					// GIF is always downscaled for a sane file size. Honor an
					// explicit 480/720 pick; otherwise keep the 480px-wide default.
					const gifScale =
						resHeight !== null
							? `scale=-2:'min(ih,${resHeight})':flags=lanczos`
							: 'scale=480:-2:flags=lanczos';
					return [
						...trimArgs,
						'-i',
						inputName,
						'-vf',
						`fps=10,${gifScale}`,
						outputName,
					];
				}
				case 'mp3':
					// Audio only — resolution is irrelevant.
					return [
						...trimArgs,
						'-i',
						inputName,
						'-vn',
						'-acodec',
						'libmp3lame',
						outputName,
					];
				default:
					throw new Error(`Unsupported format: ${format}`);
			}
		}

		function mimeTypeFor(format: string): string {
			switch (format) {
				case 'mp4':
					return 'video/mp4';
				case 'webm':
					return 'video/webm';
				case 'gif':
					return 'image/gif';
				case 'mp3':
					return 'audio/mpeg';
				default:
					return 'application/octet-stream';
			}
		}

		// Turn an ffmpeg failure into an honest, specific message using the
		// captured log tail.
		function diagnoseFailure(format: string, exitCode: number | null): string {
			const tail = recentLogs.slice(-40).join('\n');
			if (
				format === 'mp3' &&
				/(does not contain any stream|matches no streams|Stream specifier .*matches no)/i.test(tail)
			) {
				return 'This video has no audio track, so there is no audio to extract as MP3.';
			}
			if (/does not contain any stream/i.test(tail)) {
				return 'FFmpeg could not find any usable audio/video stream in this file.';
			}
			if (/(Invalid data found when processing input|moov atom not found|EBML header parsing failed|Format .* detected only with low score)/i.test(tail)) {
				return 'This file does not appear to be a real video — it may be corrupt, incomplete, or another file type renamed to a video extension.';
			}
			if (/No such file or directory/i.test(tail)) {
				return 'FFmpeg could not read this file. It may be corrupt or empty.';
			}
			return exitCode !== null
				? `Conversion failed (FFmpeg exit code ${exitCode}). The file may use an unsupported codec or be too large for available memory.`
				: 'Conversion failed. The file may use an unsupported codec or be too large for available memory.';
		}

		async function convertOne(
			item: QueueItem,
			format: string,
			trim: { start: number | null; end: number | null },
			resHeight: number | null,
		): Promise<boolean> {
			const card = document.getElementById(
				`card-${item.id}`,
			) as HTMLDivElement | null;
			if (!card) return false;

			currentCard = card;
			setCardStatus(card, 'Preparing…');

			// Fail fast on empty files instead of feeding ffmpeg nothing.
			if (item.file.size === 0) {
				setCardStatus(card, 'Error: this file is empty (0 bytes) — nothing to convert.', true);
				currentCard = null;
				return false;
			}

			const inputExt = extensionOf(item.file.name) || 'mp4';
			const inputName = `input-${item.id}.${inputExt}`;
			const outputName = `output-${item.id}.${format}`;

			try {
				const engine = await getFfmpeg();
				const { fetchFile } = await import('@ffmpeg/util');

				setCardStatus(card, 'Preparing file…');
				const data = await fetchFile(item.file);
				await engine.writeFile(inputName, data);

				setCardStatus(
					card,
					format === 'webm' ? 'Converting… (WebM is slower — hang tight)' : 'Converting…',
				);
				recentLogs = [];
				const exitCode: number = await engine.exec(
					buildCommand(inputName, outputName, format, trim, resHeight),
				);
				if (exitCode !== 0) {
					throw new Error(diagnoseFailure(format, exitCode));
				}

				const outputData = await engine.readFile(outputName);
				const blob = new Blob([outputData.buffer], {
					type: mimeTypeFor(format),
				});
				if (blob.size === 0) {
					throw new Error(diagnoseFailure(format, null));
				}
				const url = URL.createObjectURL(blob);

				const baseName = item.file.name.replace(/\.[^/.]+$/, '') || 'converted';
				const filename = `${baseName}.${format}`;

				setCardProgress(card, 100);
				setCardStatus(card, `Done — ${(blob.size / 1024 / 1024).toFixed(2)} MB`);
				setCardAction(card, url, filename);

				try {
					await engine.deleteFile(inputName);
				} catch {
					// ignore if already gone
				}
				try {
					await engine.deleteFile(outputName);
				} catch {
					// ignore if already gone
				}
				return true;
			} catch (err) {
				console.error(err);
				const rawMessage =
					err instanceof Error
						? err.message
						: typeof err === 'string'
							? err
							: String((err as any)?.message ?? 'unknown error');
				// A wasm crash kills the whole engine — reset it so the rest of
				// the batch (and the next run) still works.
				const isCrash = /memory access out of bounds|RuntimeError|unreachable|Aborted/i.test(rawMessage);
				if (isCrash || /FS error/i.test(rawMessage)) {
					resetEngine();
				}
				const message = isCrash
					? 'The converter engine ran out of memory on this file. Try a shorter clip (use Trim above) or a smaller file.'
					: /FS error/i.test(rawMessage)
						? diagnoseFailure(format, null)
						: rawMessage;
				setCardStatus(card, `Error: ${message}`, true);
				return false;
			} finally {
				currentCard = null;
			}
		}

		convertBtn.addEventListener('click', async () => {
			if (queue.length === 0 || isProcessing) return;

			clearError();

			let trim: { start: number | null; end: number | null };
			try {
				trim = readTrimRange();
			} catch (err) {
				showError(err instanceof Error ? err.message : String(err));
				return;
			}

			const resHeight = readResolution();

			isProcessing = true;
			convertBtn.disabled = true;
			fileInput.disabled = true;
			formatSelect.disabled = true;
			trimStartInput.disabled = true;
			trimEndInput.disabled = true;
			trimStartRange.disabled = true;
			trimEndRange.disabled = true;
			resSelect.disabled = true;
			hideRemoveButtons();
			snakeOnProcessingStart();

			const format = formatSelect.value;
			const batch = queue;
			let succeeded = 0;

			if (trim.start !== null || trim.end !== null) {
				const from = trim.start !== null ? formatSeconds(trim.start) : 'start';
				const to = trim.end !== null ? formatSeconds(trim.end) : 'end';
				showEngineStatus(`Converting segment ${from} → ${to}…`, 0);
			}

			try {
				// Process sequentially — ffmpeg.wasm runs one job at a time.
				for (const item of batch) {
					const ok = await convertOne(item, format, trim, resHeight);
					if (ok) succeeded += 1;
				}
				const failed = batch.length - succeeded;
				showEngineStatus(
					failed === 0
						? `All ${batch.length === 1 ? 'done' : `${batch.length} conversions done`}`
						: `Finished — ${succeeded} of ${batch.length} converted, ${failed} failed`,
					100,
				);
			} catch (err) {
				console.error(err);
				showError(
					'Something went wrong loading the conversion engine. Check your connection and try reloading the page.',
				);
				hideEngineStatus();
			} finally {
				// The batch is finished — clear the queue so the next Convert
				// doesn't silently re-convert everything again.
				queue = [];
				isProcessing = false;
				fileInput.disabled = false;
				formatSelect.disabled = false;
				trimStartInput.disabled = false;
				trimEndInput.disabled = false;
				resSelect.disabled = false;
				// Reset the trim UI so a stale duration from the finished batch
				// doesn't linger for the next set of files.
				trimStartInput.value = '';
				trimEndInput.value = '';
				disableSliders(
					'Select one or more videos and the sliders snap to the first video’s length.',
				);
				renderQueueButtonState();
				snakeOnProcessingEnd();
			}
		});

		// ---------- Snake boredom-filler ----------
		// Always available as a collapsible <details> card, and auto-surfaced
		// during a (potentially slow) conversion. The game loop only runs while
		// the card is open, so it costs nothing when collapsed.

		const snakeDetails = document.getElementById('snake-details') as HTMLDetailsElement;
		const snakeSummaryText = document.getElementById('snake-summary-text') as HTMLSpanElement;
		const cv = document.getElementById('snake-canvas') as HTMLCanvasElement | null;
		const ctx = cv ? cv.getContext('2d') : null;
		const scoreEl = document.getElementById('snake-score') as HTMLElement | null;

		const G = 16;
		const N = 20; // 320 / 16
		let snake: { x: number; y: number }[] = [];
		let dir = { x: 0, y: 0 };
		let food = { x: 0, y: 0 };
		let score = 0;
		let alive = true;
		let snakeTimer: ReturnType<typeof setInterval> | null = null;

		function rndFood() {
			return {
				x: Math.floor(Math.random() * N),
				y: Math.floor(Math.random() * N),
			};
		}

		function snakeReset() {
			snake = [{ x: 10, y: 10 }];
			dir = { x: 0, y: 0 };
			food = rndFood();
			score = 0;
			alive = true;
			if (scoreEl) scoreEl.textContent = '0';
			snakeDraw();
		}

		function snakeStep() {
			if (!alive || !ctx || !cv) return;
			if (dir.x === 0 && dir.y === 0) {
				snakeDraw();
				return;
			}
			const h = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };
			if (
				h.x < 0 || h.y < 0 || h.x >= N || h.y >= N ||
				snake.some((s) => s.x === h.x && s.y === h.y)
			) {
				alive = false;
				snakeDraw();
				return;
			}
			snake.unshift(h);
			if (h.x === food.x && h.y === food.y) {
				score++;
				if (scoreEl) scoreEl.textContent = String(score);
				food = rndFood();
			} else {
				snake.pop();
			}
			snakeDraw();
		}

		function snakeDraw() {
			if (!ctx || !cv) return;
			ctx.fillStyle = '#ffffff';
			ctx.fillRect(0, 0, cv.width, cv.height);
			ctx.fillStyle = '#c9982e';
			snake.forEach((s) => ctx.fillRect(s.x * G + 1, s.y * G + 1, G - 2, G - 2));
			ctx.fillStyle = '#221b10';
			ctx.fillRect(food.x * G + 3, food.y * G + 3, G - 6, G - 6);
			if (!alive) {
				ctx.fillStyle = 'rgba(34,27,16,0.72)';
				ctx.fillRect(0, 0, cv.width, cv.height);
				ctx.fillStyle = '#fff';
				ctx.font = 'bold 20px Sora, sans-serif';
				ctx.textAlign = 'center';
				ctx.fillText('Game Over — Restart', cv.width / 2, cv.height / 2);
			}
		}

		function turn(x: number, y: number) {
			if ((x !== 0 && dir.x === 0) || (y !== 0 && dir.y === 0)) dir = { x, y };
		}

		function snakeIsOpen(): boolean {
			return !!snakeDetails && snakeDetails.open;
		}

		function snakeLoopStart() {
			if (snakeTimer) return;
			snakeReset();
			snakeTimer = setInterval(snakeStep, 110);
		}

		function snakeLoopStop() {
			if (snakeTimer) {
				clearInterval(snakeTimer);
				snakeTimer = null;
			}
		}

		if (cv && ctx) {
			// Only steer while the card is open, and never hijack keys from a text
			// field / select.
			window.addEventListener(
				'keydown',
				(e) => {
					if (!snakeIsOpen()) return;
					const target = e.target as HTMLElement | null;
					if (target && /^(INPUT|SELECT|TEXTAREA)$/.test(target.tagName)) return;
					const k = e.key.toLowerCase();
					if (['arrowup', 'w'].includes(k)) turn(0, -1);
					else if (['arrowdown', 's'].includes(k)) turn(0, 1);
					else if (['arrowleft', 'a'].includes(k)) turn(-1, 0);
					else if (['arrowright', 'd'].includes(k)) turn(1, 0);
					else return;
					e.preventDefault();
				},
				{ passive: false },
			);

			let tx = 0,
				ty = 0;
			cv.addEventListener(
				'touchstart',
				(e) => {
					tx = e.touches[0].clientX;
					ty = e.touches[0].clientY;
				},
				{ passive: true },
			);
			cv.addEventListener(
				'touchend',
				(e) => {
					const dx = e.changedTouches[0].clientX - tx;
					const dy = e.changedTouches[0].clientY - ty;
					if (Math.abs(dx) > Math.abs(dy)) turn(dx > 0 ? 1 : -1, 0);
					else turn(0, dy > 0 ? 1 : -1);
				},
				{ passive: true },
			);

			document
				.getElementById('snake-restart')
				?.addEventListener('click', snakeReset);

			// Run the loop only while the card is open.
			snakeDetails?.addEventListener('toggle', () => {
				if (snakeDetails.open) snakeLoopStart();
				else snakeLoopStop();
			});

			snakeReset();
		}

		// Conversion is a potentially slow operation — surface the game more
		// prominently while it runs (open the card + swap in the "this can take a
		// moment" copy), then quietly restore the default copy afterwards.
		const SNAKE_DEFAULT_COPY = 'Bored? Play a quick game of Snake';
		const SNAKE_BUSY_COPY =
			'This can take a moment — play a round of Snake while you wait';

		function snakeOnProcessingStart() {
			if (snakeSummaryText) snakeSummaryText.textContent = SNAKE_BUSY_COPY;
			if (snakeDetails && !snakeDetails.open) {
				snakeDetails.open = true;
				snakeLoopStart();
			}
		}

		function snakeOnProcessingEnd() {
			if (snakeSummaryText) snakeSummaryText.textContent = SNAKE_DEFAULT_COPY;
			// Leave the card in whatever state the user left it; just make sure the
			// loop reflects the open/closed state.
			if (snakeDetails && !snakeDetails.open) snakeLoopStop();
		}
	</script>
</Layout>
